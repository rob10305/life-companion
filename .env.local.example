# GitHub Personal Access Token (required for Import from GitHub feature)
# Create at: https://github.com/settings/tokens → Generate new token (classic)
# Required scopes: repo (includes private repos) or public_repo (public only)
GITHUB_TOKEN=ghp_your_token_here

# Optional: Add Supabase credentials to enable cross-device sync.
# Without these, the app uses localStorage (data stays on one device).
# Get these from: https://supabase.com → Your project → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
